# ==============================
# Скопируй в .env и заполни:
# cp .env.example .env
# ==============================

# Домен (A-запись → IP сервера)
DOMAIN=example.com

# CDN-субдомен для WebSocket/XHTTP через Cloudflare (опционально)
# Если не нужен — оставь пустым или удали строку
# CDN=cdn.example.com

# Email для Let's Encrypt
EMAIL=admin@example.com

# SSH порт (нестандартный снижает шум от ботов)
# После смены: ssh -p 2222 user@host
SSH_PORT=2222

# Timezone
TZ=Europe/Moscow
