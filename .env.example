# ==============================
# Скопируй в .env и заполни
# cp .env.example .env
# ==============================

# Основной домен (A-запись → IP сервера)
DOMAIN=example.com

# Email для Let's Encrypt уведомлений
EMAIL=admin@example.com

# Timezone
TZ=Europe/Moscow

# Порт MTProxy для Telegram (публичный)
MTPROXY_PORT=8443

# Порт веб-панели Blitz (выбирай нестандартный)
BLITZ_PORT=2096

# SSH порт (нестандартный снижает шум от ботов)
# После смены: ssh -p 2222 user@host
SSH_PORT=2222
